rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Joint Log data lives in the single document joint/tl_joint_v1.
    // Restrict all reads/writes to your one shared account.
    // Replace YOUR_UID_HERE with the User UID from Firebase → Authentication → Users.
    match /joint/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == "YOUR_UID_HERE";
    }
  }
}
